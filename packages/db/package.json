{
  "name": "@property-lk/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "default": "./dist/client.js"
    },
    "./queries": {
      "types": "./dist/queries/index.d.ts",
      "default": "./dist/queries/index.js"
    },
    "./mutations": {
      "types": "./dist/mutations/index.d.ts",
      "default": "./dist/mutations/index.js"
    },
    "./package.json": "./package.json"
  },
  "typesVersions": {
    "*": {
      "client": [
        "./dist/client.d.ts"
      ],
      "queries": [
        "./dist/queries/index.d.ts"
      ],
      "mutations": [
        "./dist/mutations/index.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "prisma"
  ],
  "scripts": {
    "generate": "prisma generate",
    "build": "pnpm run generate && tsc -p tsconfig.json",
    "lint": "pnpm run generate && tsc -p tsconfig.json --noEmit",
    "typecheck": "pnpm run generate && tsc -p tsconfig.json --noEmit",
    "test": "tsx --test tests/**/*.test.ts",
    "seed": "prisma db seed"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@property-lk/search": "workspace:*",
    "@property-lk/types": "workspace:*",
    "@prisma/client": "^6.5.0"
  },
  "devDependencies": {
    "prisma": "^6.5.0",
    "tsx": "^4.19.3",
    "@types/node": "^22.10.0",
    "typescript": "^5.8.2"
  }
}

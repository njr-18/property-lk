{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "preserve",
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@property-lk/db": [
        "../../packages/db/src/index.ts"
      ],
      "@property-lk/db/client": [
        "../../packages/db/src/client.ts"
      ],
      "@property-lk/search": [
        "../../packages/search/src/index.ts"
      ],
      "@property-lk/seo": [
        "../../packages/seo/src/index.ts"
      ],
      "@property-lk/types": [
        "../../packages/types/src/index.ts"
      ],
      "@property-lk/ui": [
        "../../packages/ui/src/index.ts"
      ],
      "@property-lk/validation": [
        "../../packages/validation/src/index.ts"
      ],
      "@/*": [
        "./*"
      ]
    },
    "plugins": [
      {
        "name": "next"
      }
    ],
    "isolatedModules": true
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}

{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "env": [
        "DATABASE_URL",
        "NEXT_PUBLIC_SITE_URL",
        "SESSION_SECRET"
      ],
      "outputs": [
        ".next/**",
        "dist/**"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": [
        "build",
        "^build"
      ]
    },
    "typecheck": {
      "dependsOn": [
        "build",
        "^build"
      ],
      "outputs": []
    },
    "test": {
      "dependsOn": [
        "^test"
      ],
      "outputs": [
        "coverage/**"
      ]
    },
    "seed": {
      "cache": false,
      "outputs": []
    },
    "format": {
      "cache": false
    }
  }
}
